# ── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0
ADMIN_SECRET=change-me-to-a-random-secret

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://accountos:accountos@localhost:5432/accountos

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Nomba API ────────────────────────────────────────
NOMBA_API_BASE_URL=https://api.nomba.com/v1
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_ACCOUNT_ID=
NOMBA_WEBHOOK_HMAC_SECRET=

# Set to "true" to skip real Nomba API calls (uses in-memory mock responses)
NOMBA_MOCK_MODE=true

# ── Encryption ──────────────────────────────────────────
# AES-256 encryption key for Nomba credentials at rest (at least 32 characters)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-to-a-32-char-minimum-encryption-key!!!

# ── Rate Limiting ────────────────────────────────────
THROTTLE_ADMIN_LIMIT=10
THROTTLE_ADMIN_TTL=60000
THROTTLE_WEBHOOK_LIMIT=100
THROTTLE_WEBHOOK_TTL=60000
THROTTLE_API_LIMIT=300
THROTTLE_API_TTL=60000
